				</dessicatedBodyGraphicData>
			</li>
			<li>
				<bodyGraphicData>
					<texPath>Things/Pawn/Animal/Mashed_Ashlands_Rachnoid/Mashed_Ashlands_RachnoidGlowing</texPath>
					<drawSize>1.7</drawSize>
					<shadowData>
						<volume>(0.2, 0.3, 0.2)</volume>
