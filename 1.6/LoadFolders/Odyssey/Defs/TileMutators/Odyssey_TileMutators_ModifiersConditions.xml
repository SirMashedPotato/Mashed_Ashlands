<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ==========[Mashed_Ashlands_LingeringAshClouds]==========-->
	<TileMutatorDef>
		<defName>Mashed_Ashlands_LingeringAshClouds</defName>
		<label>lingering ash clouds</label>
		<description>Large ash clouds constantly linger over this region, blocking sunlight and reducing the local temperature.</description>
		<chanceOnNonLandmarkTile>0.01</chanceOnNonLandmarkTile>
		<categories>
			<li>Weather</li>
		</categories>
		<additionalGameConditions>
			<li>Mashed_Ashlands_DenseAshCloudsLingering</li>
		</additionalGameConditions>
		<biomeWhitelist>
			<!-- Blighted -->
			<li>Mashed_Ashlands_BlightedAshlands</li>
			<li>Mashed_Ashlands_BlightedBogAshlands</li>
			<li>Mashed_Ashlands_BlightedPetrifiedForestAshlands</li>
			<!-- Regular -->
			<li>Mashed_Ashlands_Ashlands</li>
			<li>Mashed_Ashlands_DustplainAshlands</li>
			<li>Mashed_Ashlands_GrazelandAshlands</li>
			<li>Mashed_Ashlands_HighlandAshlands</li>
			<li>Mashed_Ashlands_SwampAshlands</li>
			<!-- Volcanic -->
			<li>Mashed_Ashlands_VolcanicAshlands</li>
			<li>Mashed_Ashlands_VolcanicBadlandAshlands</li>
			<li>Mashed_Ashlands_VolcanicBasaltHillsAshlands</li>
			<li>Mashed_Ashlands_VolcanicGroveAshlands</li>
			<li>Mashed_Ashlands_VolcanicSulphurPitsAshlands</li>
		</biomeWhitelist>
	</TileMutatorDef>
	<!-- ==========[Mashed_Ashlands_PersistentVolcanicHeat]==========-->
	<TileMutatorDef>
		<defName>Mashed_Ashlands_PersistentVolcanicHeat</defName>
		<label>persistent volcanic heat</label>
		<description>This region suffers from increased volcanic activity, permanently increasing the local temperature.</description>
		<chanceOnNonLandmarkTile>0.03</chanceOnNonLandmarkTile>
		<additionalGameConditions>
			<li>Mashed_Ashlands_VolcanicHeatPersistent</li>
		</additionalGameConditions>
		<biomeWhitelist>
			<!-- Volcanic -->
			<li>Mashed_Ashlands_VolcanicAshlands</li>
			<li>Mashed_Ashlands_VolcanicBasaltHillsAshlands</li>
		</biomeWhitelist>
	</TileMutatorDef>
	<!-- ==========[Mashed_Ashlands_Miasmic]==========-->
	<TileMutatorDef>
		<defName>Mashed_Ashlands_Miasmic</defName>
		<label>miasmic</label>
		<description>A large buildup of volcanic miasma can be found trapped underwater here. Tectonic activity will periodically disturb the miasma, bathing the area in toxic gasses for a few days.</description>
		<chanceOnNonLandmarkTile>0.01</chanceOnNonLandmarkTile>
		<biomeWhitelist>
			<!-- Blighted -->
			 <li>Mashed_Ashlands_BlightedBogAshlands</li>
			<!-- Regular -->
			<li>Mashed_Ashlands_SwampAshlands</li>
			<!-- Thriving -->
			<li>Mashed_Ashlands_MarshAshlands</li>
			<!-- Volcanic -->
			 <li>Mashed_Ashlands_VolcanicSulphurPitsAshlands</li>
		</biomeWhitelist>
	</TileMutatorDef>
</Defs>