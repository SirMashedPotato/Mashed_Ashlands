<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<BiomeDef ParentName="Mashed_Ashlands_AshlandsVolcanicBase">
		<defName>Mashed_Ashlands_VolcanicGroveAshlands</defName>
		<label>volcanic grove</label>
		<description>A relatively hopsitable climate and pockets of rich volcanic ash have allowed flora to flourish here, despite the region being highly volcanically active. The abundance of flora in turns attracts a wide range of fauna.</description>
		<workerClass>Mashed_Ashlands.BiomeWorker_VolcanicGroveAshlands</workerClass>
		<texture>Terrain/Biomes/Mashed_Ashlands_VolcanicGroveAshlands</texture>
		<modExtensions>
			<li Class="Mashed_Ashlands.BiomeProperties">
				<lateLoader>true</lateLoader>
				<dryToReplacers>
					<Gravel>Mashed_Ashlands_AshGravelVolcanic</Gravel>
					<Soil>Mashed_Ashlands_AshSoilVolcanic</Soil>
				</dryToReplacers>
				<roadReplacers>
					<PackedDirt>Mashed_Ashlands_PackedAshVolcanic</PackedDirt>
				</roadReplacers>
			</li>
			<li Class="BiomesKit.BiomesKitControls" MayRequireAnyOf="zal.wmbp,regrowth.botr.core">	
				<forested>true</forested>
				<uniqueHills>true</uniqueHills>
				<materialRandomRotation>false</materialRandomRotation>
				<smallHillSizeMultiplier>1.5</smallHillSizeMultiplier>
				<largeHillSizeMultiplier>2</largeHillSizeMultiplier>
				<mountainSizeMultiplier>1.4</mountainSizeMultiplier>
				<impassableSizeMultiplier>1.3</impassableSizeMultiplier>
			</li>
			<li Class="FirefliesTwoO.NightlySpawningExtension" MayRequire="scurvyez.firefliestwo">
				<biomeEmissionRate>0.6</biomeEmissionRate>
			</li>
		</modExtensions>
		<forageability>0.75</forageability>
		<foragedFood>Mashed_Ashlands_RawAshFungus</foragedFood>
		<animalDensity>3</animalDensity>
		<plantDensity>0.8</plantDensity>
		<!-- Fishing -->
		<fishTypes>
			<freshwater_Common>
				<Mashed_Ashlands_Fish_AshBlindfish MayRequire="ludeon.rimworld.odyssey">1</Mashed_Ashlands_Fish_AshBlindfish>
				<Mashed_Ashlands_Fish_NetchHookEel MayRequire="ludeon.rimworld.odyssey">1</Mashed_Ashlands_Fish_NetchHookEel>
				<Mashed_Ashlands_Fish_PilgrimGoby MayRequire="ludeon.rimworld.odyssey">1</Mashed_Ashlands_Fish_PilgrimGoby>
			</freshwater_Common>
			<freshwater_Uncommon>
				<Mashed_Ashlands_Fish_Gourami MayRequire="ludeon.rimworld.odyssey">1</Mashed_Ashlands_Fish_Gourami>
				<Mashed_Ashlands_Fish_Mouthbrooder MayRequire="ludeon.rimworld.odyssey">1</Mashed_Ashlands_Fish_Mouthbrooder>
				<Mashed_Ashlands_Fish_ToadstoolTilapia MayRequire="ludeon.rimworld.odyssey">1</Mashed_Ashlands_Fish_ToadstoolTilapia>
			</freshwater_Uncommon>
		</fishTypes>
		<!-- Weather -->
		<baseWeatherCommonalities>
			<TorrentialRain MayRequire="Ludeon.RimWorld.Odyssey">0.5</TorrentialRain>
		</baseWeatherCommonalities>
		<!-- Terrain -->
		<terrainsByFertility>
			<li>
				<terrain>Mashed_Ashlands_AshSandVolcanic</terrain>
				<min>-999</min>
				<max>0.5</max>
			</li>
			<li>
				<terrain>Mashed_Ashlands_AshGravelVolcanic</terrain>
				<min>0.5</min>
				<max>0.7</max>
			</li>
			<li>
				<terrain>Mashed_Ashlands_AshSoilVolcanic</terrain>
				<min>0.7</min>
				<max>0.86</max>
			</li>
			<li>
				<terrain>Mashed_Ashlands_RichAshSoilVolcanic</terrain>
				<min>0.86</min>
				<max>999</max>
			</li>
		</terrainsByFertility>
		<terrainPatchMakers>
			<li>
				<perlinFrequency>0.015</perlinFrequency>
				<isPond>true</isPond>
				<thresholds>
					<li>
						<terrain>Mashed_Ashlands_AshSoilVolcanic</terrain>
						<min>0.56</min>
						<max>0.68</max>
					</li>
					<li>
						<terrain>Mashed_Ashlands_RichAshSoilVolcanic</terrain>
						<min>0.68</min>
						<max>0.96</max>
					</li>
					<li>
						<terrain>Mashed_Ashlands_ShallowVolcanicWater</terrain>
						<min>0.96</min>
						<max>99</max>
					</li>
				</thresholds>
			</li>
		</terrainPatchMakers>
		<wildPlants>
			<!-- Ground covers -->
			<Plant_Grass>6</Plant_Grass>
			<Mashed_Ashlands_Plant_CharredAshlandGrass>10</Mashed_Ashlands_Plant_CharredAshlandGrass>
			<Mashed_Ashlands_Plant_AshlandDuneGrassDark>0.2</Mashed_Ashlands_Plant_AshlandDuneGrassDark>
			<Mashed_Ashlands_Plant_AshlandFungus>0.2</Mashed_Ashlands_Plant_AshlandFungus>
			<!-- Nutrition plants -->
			<Mashed_Ashlands_Plant_AshYam>0.05</Mashed_Ashlands_Plant_AshYam>
			<Mashed_Ashlands_Plant_Buttercake>0.2</Mashed_Ashlands_Plant_Buttercake>
			<Mashed_Ashlands_Plant_Scathecraw>0.2</Mashed_Ashlands_Plant_Scathecraw>
			<Mashed_Ashlands_Plant_AshPomegranate>0.06</Mashed_Ashlands_Plant_AshPomegranate>
			<Mashed_Ashlands_Plant_Marshmerrow>0.1</Mashed_Ashlands_Plant_Marshmerrow>
			<!-- Resource plants -->
			<Mashed_Ashlands_Plant_Kreshweed>0.05</Mashed_Ashlands_Plant_Kreshweed>
			<Mashed_Ashlands_Plant_MuckSponge>0.05</Mashed_Ashlands_Plant_MuckSponge>
			<Mashed_Ashlands_Plant_ParasolBush>0.1</Mashed_Ashlands_Plant_ParasolBush>
			<Mashed_Ashlands_Plant_Chillshroom>0.05</Mashed_Ashlands_Plant_Chillshroom>
			<Mashed_Ashlands_Plant_TramaShrub>0.2</Mashed_Ashlands_Plant_TramaShrub>
			<!-- Aesthetic plants -->
			<Mashed_Ashlands_Plant_AshenDaylilyFlowerOrange>0.4</Mashed_Ashlands_Plant_AshenDaylilyFlowerOrange>
			<Mashed_Ashlands_LavaBloom>0.2</Mashed_Ashlands_LavaBloom>
			<Mashed_Ashlands_Plant_FoyadaFungus>0.05</Mashed_Ashlands_Plant_FoyadaFungus>
			<Mashed_Ashlands_Plant_FireFern>0.05</Mashed_Ashlands_Plant_FireFern>
			<Mashed_Ashlands_Plant_AshlandFernGreen>0.2</Mashed_Ashlands_Plant_AshlandFernGreen>
			<!-- Aquatic plants -->
			<Mashed_Ashlands_Plant_AshreedWater>0.2</Mashed_Ashlands_Plant_AshreedWater>
			<!-- Trees -->
			<Plant_TreeCecropia>0.2</Plant_TreeCecropia>
			<Plant_TreePalm>0.4</Plant_TreePalm>
			<Mashed_Ashlands_Plant_TreeNetchShield>0.6</Mashed_Ashlands_Plant_TreeNetchShield>
			<Mashed_Ashlands_Plant_TreeMilkcap>0.1</Mashed_Ashlands_Plant_TreeMilkcap>
			<Mashed_Ashlands_Plant_TreeSpongecap>0.1</Mashed_Ashlands_Plant_TreeSpongecap>
			<Mashed_Ashlands_Plant_TreeWeepingLeathercap>0.2</Mashed_Ashlands_Plant_TreeWeepingLeathercap>
			<Mashed_Ashlands_Plant_TreeEmperorParasol>0.4</Mashed_Ashlands_Plant_TreeEmperorParasol>
			<Mashed_Ashlands_BurnedParasolStumpPermanent>0.05</Mashed_Ashlands_BurnedParasolStumpPermanent>
			<Mashed_Ashlands_BurnedStumpPermanent>0.05</Mashed_Ashlands_BurnedStumpPermanent>
			<RB_Plant_Hive_Arctic MayRequire="sarg.rimbees">0.01</RB_Plant_Hive_Arctic>
			<RB_Plant_Hive_Icy MayRequire="sarg.rimbees">0.01</RB_Plant_Hive_Icy>
			<!-- ==========[Pollution]========== -->
			<!-- Polluted ground covers -->
			<Plant_GrayGrass MayRequire="Ludeon.RimWorld.Biotech">8</Plant_GrayGrass>
			<Mashed_Ashlands_GlowingEntoloma MayRequire="Ludeon.RimWorld.Biotech">0.5</Mashed_Ashlands_GlowingEntoloma>
			<Mashed_Ashlands_Plant_GlowingAshreed MayRequire="Ludeon.RimWorld.Biotech">0.2</Mashed_Ashlands_Plant_GlowingAshreed>
			<!-- Polluted nutrition plants -->
			<Mashed_Ashlands_Plant_ToxYam MayRequire="Ludeon.RimWorld.Biotech">0.05</Mashed_Ashlands_Plant_ToxYam>
			<Mashed_Ashlands_Plant_Blightcap MayRequire="Ludeon.RimWorld.Biotech">0.3</Mashed_Ashlands_Plant_Blightcap>
			<Mashed_Ashlands_Plant_GlowingScathecraw MayRequire="Ludeon.RimWorld.Biotech">0.4</Mashed_Ashlands_Plant_GlowingScathecraw>
			<Mashed_Ashlands_Plant_GlowingParasolBush MayRequire="Ludeon.RimWorld.Biotech">0.2</Mashed_Ashlands_Plant_GlowingParasolBush>
			<!-- Polluted resource plants -->
			<Mashed_Ashlands_Plant_WasteSponge MayRequire="Ludeon.RimWorld.Biotech">0.1</Mashed_Ashlands_Plant_WasteSponge>
			<Mashed_Ashlands_Plant_TramaMass MayRequire="Ludeon.RimWorld.Biotech">0.3</Mashed_Ashlands_Plant_TramaMass>
			<!-- Polluted aesthetic plants -->
			<Mashed_Ashlands_Plant_SporangiumFlowerOrange MayRequire="Ludeon.RimWorld.Biotech">0.6</Mashed_Ashlands_Plant_SporangiumFlowerOrange>
			<Mashed_Ashlands_Plant_SporangiumFlowerWhite MayRequire="Ludeon.RimWorld.Biotech">0.3</Mashed_Ashlands_Plant_SporangiumFlowerWhite>
			<!-- Polluted aquatic plants -->
			<Mashed_Ashlands_Plant_GlowingAshreedWater MayRequire="Ludeon.RimWorld.Biotech">0.1</Mashed_Ashlands_Plant_GlowingAshreedWater>
			<!-- Polluted trees -->
			<Mashed_Ashlands_GiantAshlandFungus MayRequire="Ludeon.RimWorld.Biotech">0.8</Mashed_Ashlands_GiantAshlandFungus>
			<Mashed_Ashlands_GiantGlowingCoprinus MayRequire="Ludeon.RimWorld.Biotech">0.6</Mashed_Ashlands_GiantGlowingCoprinus>
			<Plant_RatPalm MayRequire="Ludeon.RimWorld.Biotech">0.3</Plant_RatPalm>
			<Mashed_Ashlands_Plant_TreeWeepingMouldcap MayRequire="Ludeon.RimWorld.Biotech">0.3</Mashed_Ashlands_Plant_TreeWeepingMouldcap>
			<Mashed_Ashlands_Plant_TreeEmperorToxisol MayRequire="Ludeon.RimWorld.Biotech">0.6</Mashed_Ashlands_Plant_TreeEmperorToxisol>
		</wildPlants>
		<wildAnimals>
			<!-- prey animals -->
			<Mashed_Ashlands_BantamGuar>0.1</Mashed_Ashlands_BantamGuar>
			<Mashed_Ashlands_Scuttler>0.3</Mashed_Ashlands_Scuttler>
			<Mashed_Ashlands_AshHopper>0.1</Mashed_Ashlands_AshHopper>
			<Mashed_Ashlands_Vvardvark>0.2</Mashed_Ashlands_Vvardvark>
			<!-- herd animals -->
			<Mashed_Ashlands_Thunderbug>0.1</Mashed_Ashlands_Thunderbug>
			<Mashed_Ashlands_Firebug>0.05</Mashed_Ashlands_Firebug>
			<Mashed_Ashlands_Shalk>0.1</Mashed_Ashlands_Shalk>
			<Mashed_Ashlands_ShalkFungal>0.2</Mashed_Ashlands_ShalkFungal>
			<Mashed_Ashlands_NixOx>0.1</Mashed_Ashlands_NixOx>
			<Mashed_Ashlands_Netch>0.3</Mashed_Ashlands_Netch>
			<Mashed_Ashlands_Guar>0.3</Mashed_Ashlands_Guar>
			<Mashed_Ashlands_Rotumbo>0.2</Mashed_Ashlands_Rotumbo>
			<Mashed_Ashlands_Wormmouth>0.1</Mashed_Ashlands_Wormmouth>
			<!-- predators -->
			<Mashed_Ashlands_NixHound>0.3</Mashed_Ashlands_NixHound>
			<Mashed_Ashlands_Rachnoid>0.3</Mashed_Ashlands_Rachnoid>
			<Mashed_Ashlands_Kagouti>0.2</Mashed_Ashlands_Kagouti>
			<Mashed_Ashlands_Alit>0.2</Mashed_Ashlands_Alit>
			<Mashed_Ashlands_CliffRacer>0.1</Mashed_Ashlands_CliffRacer>
			<!-- ESCP Trolls -->
			<ESCP_TrollBarren MayRequire="escp.trolls">0.01</ESCP_TrollBarren>
			<ESCP_TrollPygmy MayRequire="escp.trolls">0.05</ESCP_TrollPygmy>
			<ESCP_TrollFungal MayRequire="escp.trolls">0.05</ESCP_TrollFungal>
			<ESCP_TrollHill MayRequire="escp.trolls">0.025</ESCP_TrollHill>
			<ESCP_TrollCave MayRequire="escp.trolls">0.025</ESCP_TrollCave>
			<ESCP_TrollCoastal MayRequire="escp.trolls">0.025</ESCP_TrollCoastal>
			<ESCP_TrollUdyrfrykte MayRequire="escp.trolls">0.01</ESCP_TrollUdyrfrykte>
			<!-- ESCP Spriggan-->
			<ESCP_Spriggan_Burnt MayRequire="escp.spriggan">0.01</ESCP_Spriggan_Burnt>
			<ESCP_Spriggan_Parasol MayRequire="escp.spriggan">0.05</ESCP_Spriggan_Parasol>
			<ESCP_Spriggan_Matron MayRequire="escp.spriggan">0.01</ESCP_Spriggan_Matron>
			<ESCP_Spriggan_EarthMother MayRequire="escp.spriggan">0.005</ESCP_Spriggan_EarthMother>
			<!-- special -->
		</wildAnimals>
		<pollutionWildAnimals>
			<Mashed_Ashlands_AshHopperGlowing MayRequire="Ludeon.RimWorld.Biotech">0.1</Mashed_Ashlands_AshHopperGlowing>
			<Mashed_Ashlands_ShalkGlowing MayRequire="Ludeon.RimWorld.Biotech">0.2</Mashed_Ashlands_ShalkGlowing>
			<Mashed_Ashlands_Toxbug MayRequire="Ludeon.RimWorld.Biotech">0.2</Mashed_Ashlands_Toxbug>
			<Mashed_Ashlands_NetchGlowing MayRequire="Ludeon.RimWorld.Biotech">0.2</Mashed_Ashlands_NetchGlowing>
			<Mashed_Ashlands_NixOxGlowing MayRequire="Ludeon.RimWorld.Biotech">0.05</Mashed_Ashlands_NixOxGlowing>
			<Mashed_Ashlands_RachnoidGlowing MayRequire="Ludeon.RimWorld.Biotech">0.3</Mashed_Ashlands_RachnoidGlowing>
			<Mashed_Ashlands_NixHoundGlowing MayRequire="Ludeon.RimWorld.Biotech">0.05</Mashed_Ashlands_NixHoundGlowing>
			<Mashed_Ashlands_CliffRacer>0.2</Mashed_Ashlands_CliffRacer>
		</pollutionWildAnimals>
	</BiomeDef>
</Defs>